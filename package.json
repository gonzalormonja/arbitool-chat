{
  "name": "arbitool-chat",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "bot": "node apps/bot/dist/index.js",
    "bot:build": "npm run build -w @arbitool/bot",
    "backup": "node apps/backup-processor/dist/index.js",
    "backup:build": "npm run build -w @arbitool/backup-processor",
    "build": "npm run build -w @arbitool/shared && npm run bot:build && npm run backup:build"
  },
  "engines": {
    "node": ">=18"
  }
}
